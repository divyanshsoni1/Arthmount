{
  "name": "arthmount",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:deploy": "prisma migrate deploy",
    "db:resolve": "prisma migrate resolve",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:fresh": "prisma migrate reset --force && npm run db:seed",
    "db:generate": "npm run prisma:generate",
    "script:reset": "npm run script:cleanup && npm run db:seed",
    "script:cleanup": "tsx prisma/cleanup.ts",
    "worker:otp": "tsx workers/otp-worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
